################################################################################
# GLOBAL SETTINGS                                                              #
################################################################################

# disable global configuration on macos (/etc/zprofile & /etc/zshrc)
unsetopt GLOBAL_RCS

##################################################
# LOCALE SPECIFICATION                           #
##################################################

# export LANG="en_US.UTF-8"
# export LC_ALL="${LANG}"
# export LC_CTYPE="${LANG}"

export TERM=xterm-256color

##################################################
# XDG DIRECTORY SPECIFICATION                    #
##################################################

export XDG_CACHE_HOME="${HOME}/.cache"
export XDG_CONFIG_HOME="${HOME}/.config"
export XDG_DATA_HOME="${HOME}/.local/share"
export XDG_STATE_HOME="${HOME}/.local/state"

##################################################
# HOMEBREW PACKAGE MANAGER                       #
##################################################

export HOMEBREW_REPOSITORY="/opt/homebrew"
export HOMEBREW_PREFIX="${HOMEBREW_REPOSITORY}"
export HOMEBREW_CELLAR="${HOMEBREW_REPOSITORY}/Cellar"

export HOMEBREW_NO_ENV_HINTS=1
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_INSECURE_REDIRECT=1

##################################################
# PATH                                           #
##################################################

PATH="/bin"
PATH="/sbin:${PATH}"
PATH="/usr/bin:${PATH}"
PATH="/usr/sbin:${PATH}"
PATH="${HOMEBREW_PREFIX}/bin:${PATH}"
PATH="${HOMEBREW_PREFIX}/sbin:${PATH}"
PATH="${HOMEBREW_PREFIX}/opt/gnu-tar/libexec/gnubin:${PATH}"
PATH="${HOMEBREW_PREFIX}/opt/gnu-sed/libexec/gnubin:${PATH}"
PATH="${HOMEBREW_PREFIX}/opt/coreutils/libexec/gnubin:${PATH}"
PATH="${HOMEBREW_PREFIX}/opt/findutils/libexec/gnubin:${PATH}"
PATH="${HOMEBREW_PREFIX}/opt/diffutils/bin:${PATH}"
export PATH

##################################################
# MANPATH                                        #
##################################################

MANPATH="/usr/share/man"
MANPATH="/opt/homebrew/share/man:${MANPATH}"
export MANPATH

##################################################
# FPATH                                          #
##################################################

fpath=("/usr/share/zsh/5.9/functions")
fpath=("/usr/share/zsh/site-functions" $fpath)
fpath=("${HOMEBREW_PREFIX}/share/zsh/site-functions" $fpath)

##################################################
# PROGRAMS                                       #
##################################################

export PAGER="less"
export EDITOR="nvim"
export BROWSER="firefox"


################################################################################
# ZSH SETTINGS                                                                 #
################################################################################

##################################################
# ZSH KEYBINDS                                   #
##################################################

# enable vi-mode
bindkey -v

# word-jump navigation
bindkey '^[[1;5C' forward-word
bindkey '^[[1;5D' backward-word

# cycle through historical commands
bindkey '^[[B' history-search-forward
bindkey '^[[A' history-search-backward

##################################################
# ZSH HISTORY                                    #
##################################################

# define history location and limit
HISTSIZE=10000
SAVEHIST=10000
HISTFILE="${XDG_DATA_HOME}/zsh/history"
[ ! -f "${XDG_DATA_HOME}/zsh" ] && mkdir -p "${XDG_DATA_HOME}/zsh"

# set history options
setopt append_history
setopt share_history
setopt hist_ignore_space
setopt hist_ignore_dups
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_find_no_dups

##################################################
# ZSH COMPLETIONS                                #
##################################################

zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu select _extensions _complete _approximate
zstyle ':completion:*' matcher-list '' 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'

zmodload zsh/complist

[ ! -f "${XDG_CACHE_HOME}/zsh" ] && mkdir -p "${XDG_CACHE_HOME}/zsh"
autoload -Uz compinit; compinit -i -C -d "${XDG_CACHE_HOME}/zsh/zcompcache"

_comp_options+=(globdots)


